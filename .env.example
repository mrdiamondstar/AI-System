# Copy to .env and fill in. Never commit .env.

# Postgres (Neon in Phase 1) — pooled connection string
DATABASE_URL="postgresql://user:password@host/dstarix?sslmode=require"
# Direct (non-pooled) connection for migrations
DIRECT_DATABASE_URL="postgresql://user:password@host/dstarix?sslmode=require"

# Redis (Upstash) — optional in local dev; cache degrades gracefully
REDIS_URL=""

# App
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
NODE_ENV="development"
