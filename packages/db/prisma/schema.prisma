// DStarix schema v1 — catalog core (doc 05).
// Conventions: UUIDv7 ids, snake_case tables via @@map, soft delete only where
// recovery/audit matters, money in minor units, statuses as enums.

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  directUrl  = env("DIRECT_DATABASE_URL")
  extensions = [pgcrypto, pg_trgm, vector]
}

// ---------------------------------------------------------------------------
// Identity
// Better Auth (ADR-004) will own its own auth tables when integrated; this
// User model is the app-domain profile they attach to.
// ---------------------------------------------------------------------------

enum UserRole {
  USER
  PRO
  VENDOR
  EDITOR
  MODERATOR
  ADMIN
  SUPERADMIN
}

model User {
  id            String    @id @default(uuid(7)) @db.Uuid
  email         String    @unique
  emailVerified Boolean   @default(false) @map("email_verified")
  name          String?
  image         String?
  handle        String?   @unique
  role          UserRole  @default(USER)
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  deletedAt     DateTime? @map("deleted_at")

  reviews       Review[]
  collections   Collection[]
  bookmarks     Bookmark[]
  sessions      Session[]
  accounts      Account[]
  subscriptions Subscription[]
  entitlements  Entitlement[]
  apiKeys       ApiKey[]
  listings      MarketplaceListing[]
  orders        MarketplaceOrder[]

  @@map("users")
}

// Better Auth tables (ADR-004). IDs are DB-generated UUIDv7 via
// advanced.database.generateId=false in the auth config.

model Session {
  id        String   @id @default(uuid(7)) @db.Uuid
  token     String   @unique
  userId    String   @map("user_id") @db.Uuid
  expiresAt DateTime @map("expires_at")
  ipAddress String?  @map("ip_address")
  userAgent String?  @map("user_agent")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("auth_sessions")
}

model Account {
  id                    String    @id @default(uuid(7)) @db.Uuid
  userId                String    @map("user_id") @db.Uuid
  accountId             String    @map("account_id")
  providerId            String    @map("provider_id")
  accessToken           String?   @map("access_token")
  refreshToken          String?   @map("refresh_token")
  idToken               String?   @map("id_token")
  accessTokenExpiresAt  DateTime? @map("access_token_expires_at")
  refreshTokenExpiresAt DateTime? @map("refresh_token_expires_at")
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([providerId, accountId])
  @@index([userId])
  @@map("auth_accounts")
}

model Verification {
  id         String   @id @default(uuid(7)) @db.Uuid
  identifier String
  value      String
  expiresAt  DateTime @map("expires_at")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@index([identifier])
  @@map("auth_verifications")
}

// ---------------------------------------------------------------------------
// Catalog — entity-first (doc 05 §1)
// ---------------------------------------------------------------------------

enum EntityType {
  TOOL
  AGENT
  MODEL
  API
  MCP_SERVER
}

enum EntityStatus {
  DRAFT
  IN_REVIEW
  PUBLISHED
  ARCHIVED
}

enum PricingModel {
  FREE
  FREEMIUM
  PAID
  OPEN_SOURCE
  CONTACT
}

model Company {
  id          String    @id @default(uuid(7)) @db.Uuid
  slug        String    @unique
  name        String
  websiteUrl  String?   @map("website_url")
  description String?
  logoMediaId String?   @map("logo_media_id") @db.Uuid
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")

  entities Entity[]
  jobs     Job[]

  @@map("companies")
}

model Entity {
  id             String       @id @default(uuid(7)) @db.Uuid
  type           EntityType
  status         EntityStatus @default(DRAFT)
  slug           String       @unique
  name           String
  tagline        String?
  summary        String?
  websiteUrl     String?      @map("website_url")
  affiliateUrl   String?      @map("affiliate_url")
  pricingModel   PricingModel @default(CONTACT) @map("pricing_model")
  companyId      String?      @map("company_id") @db.Uuid
  // Content-pipeline trust flags (doc 06 §6)
  aiGenerated    Boolean      @default(false) @map("ai_generated")
  lastVerifiedAt DateTime?    @map("last_verified_at")
  publishedAt    DateTime?    @map("published_at")
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")
  deletedAt      DateTime?    @map("deleted_at")

  company         Company?         @relation(fields: [companyId], references: [id])
  categories      EntityCategory[]
  tags            EntityTag[]
  pricingPlans    PricingPlan[]
  media           Media[]
  reviews         Review[]
  score           EntityScore?
  collectionItems CollectionItem[]
  bookmarks       Bookmark[]

  @@index([status, type])
  @@index([companyId])
  @@index([publishedAt])
  @@map("entities")
}

model Category {
  id          String   @id @default(uuid(7)) @db.Uuid
  slug        String   @unique
  name        String
  description String?
  parentId    String?  @map("parent_id") @db.Uuid
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  parent   Category?        @relation("CategoryTree", fields: [parentId], references: [id])
  children Category[]       @relation("CategoryTree")
  entities EntityCategory[]

  @@index([parentId])
  @@map("categories")
}

model EntityCategory {
  entityId   String  @map("entity_id") @db.Uuid
  categoryId String  @map("category_id") @db.Uuid
  isPrimary  Boolean @default(false) @map("is_primary")

  entity   Entity   @relation(fields: [entityId], references: [id], onDelete: Cascade)
  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@id([entityId, categoryId])
  @@index([categoryId])
  @@map("entity_categories")
}

model Tag {
  id   String @id @default(uuid(7)) @db.Uuid
  slug String @unique
  name String

  entities EntityTag[]

  @@map("tags")
}

model EntityTag {
  entityId String @map("entity_id") @db.Uuid
  tagId    String @map("tag_id") @db.Uuid

  entity Entity @relation(fields: [entityId], references: [id], onDelete: Cascade)
  tag    Tag    @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([entityId, tagId])
  @@index([tagId])
  @@map("entity_tags")
}

model PricingPlan {
  id               String   @id @default(uuid(7)) @db.Uuid
  entityId         String   @map("entity_id") @db.Uuid
  name             String
  // Minor units (paise/cents); null = custom/contact pricing
  priceMinor       Int?     @map("price_minor")
  currency         String   @default("USD") @db.Char(3)
  billingPeriod    String?  @map("billing_period") // monthly | yearly | one_time
  features         Json     @default("[]")
  sortOrder        Int      @default(0) @map("sort_order")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  entity Entity @relation(fields: [entityId], references: [id], onDelete: Cascade)

  @@index([entityId])
  @@map("pricing_plans")
}

// ---------------------------------------------------------------------------
// Media (doc 05 §4) — R2-backed, validated by worker before "READY"
// ---------------------------------------------------------------------------

enum MediaStatus {
  PENDING
  READY
  REJECTED
}

model Media {
  id          String      @id @default(uuid(7)) @db.Uuid
  entityId    String?     @map("entity_id") @db.Uuid
  bucket      String
  objectKey   String      @map("object_key")
  contentType String      @map("content_type")
  sizeBytes   Int         @map("size_bytes")
  altText     String?     @map("alt_text")
  status      MediaStatus @default(PENDING)
  createdAt   DateTime    @default(now()) @map("created_at")

  entity Entity? @relation(fields: [entityId], references: [id], onDelete: SetNull)

  @@unique([bucket, objectKey])
  @@index([entityId])
  @@map("media")
}

// ---------------------------------------------------------------------------
// Engagement — reviews, scores, collections, bookmarks
// ---------------------------------------------------------------------------

enum ReviewStatus {
  PENDING
  APPROVED
  REJECTED
  SPAM
}

model Review {
  id          String       @id @default(uuid(7)) @db.Uuid
  entityId    String       @map("entity_id") @db.Uuid
  userId      String       @map("user_id") @db.Uuid
  rating      Int          @db.SmallInt
  title       String?
  body        String
  status      ReviewStatus @default(PENDING)
  moderatedBy String?      @map("moderated_by") @db.Uuid
  moderatedAt DateTime?    @map("moderated_at")
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")
  deletedAt   DateTime?    @map("deleted_at")

  entity Entity @relation(fields: [entityId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id])

  // One review per user per entity
  @@unique([entityId, userId])
  @@index([entityId, status])
  @@index([userId])
  @@map("reviews")
}

// Denormalized aggregates + Decision Score (doc 07 §1). Recomputed by event
// consumers; never joined-and-aggregated at read time.
model EntityScore {
  entityId      String   @id @map("entity_id") @db.Uuid
  decisionScore Int      @default(0) @map("decision_score") @db.SmallInt
  scoreVersion  Int      @default(1) @map("score_version")
  factors       Json     @default("{}")
  ratingAvg     Decimal  @default(0) @map("rating_avg") @db.Decimal(3, 2)
  ratingCount   Int      @default(0) @map("rating_count")
  bookmarkCount Int      @default(0) @map("bookmark_count")
  computedAt    DateTime @default(now()) @map("computed_at")

  entity Entity @relation(fields: [entityId], references: [id], onDelete: Cascade)

  @@index([decisionScore])
  @@map("entity_scores")
}

enum CollectionStatus {
  DRAFT
  PUBLISHED
}

model Collection {
  id          String           @id @default(uuid(7)) @db.Uuid
  slug        String           @unique
  title       String
  description String?
  isEditorial Boolean          @default(false) @map("is_editorial")
  ownerId     String?          @map("owner_id") @db.Uuid
  status      CollectionStatus @default(DRAFT)
  createdAt   DateTime         @default(now()) @map("created_at")
  updatedAt   DateTime         @updatedAt @map("updated_at")

  owner User?            @relation(fields: [ownerId], references: [id])
  items CollectionItem[]

  @@index([ownerId])
  @@map("collections")
}

model CollectionItem {
  collectionId String   @map("collection_id") @db.Uuid
  entityId     String   @map("entity_id") @db.Uuid
  note         String?
  sortOrder    Int      @default(0) @map("sort_order")
  createdAt    DateTime @default(now()) @map("created_at")

  collection Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  entity     Entity     @relation(fields: [entityId], references: [id], onDelete: Cascade)

  @@id([collectionId, entityId])
  @@index([entityId])
  @@map("collection_items")
}

model Bookmark {
  userId    String   @map("user_id") @db.Uuid
  entityId  String   @map("entity_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  entity Entity @relation(fields: [entityId], references: [id], onDelete: Cascade)

  @@id([userId, entityId])
  @@index([entityId])
  @@map("bookmarks")
}

// ---------------------------------------------------------------------------
// SEO — slug rename 301 discipline (doc 03 §4)
// ---------------------------------------------------------------------------

model SlugRedirect {
  id         String   @id @default(uuid(7)) @db.Uuid
  entityKind String   @map("entity_kind") // entities | categories | collections | companies
  fromSlug   String   @map("from_slug")
  toSlug     String   @map("to_slug")
  createdAt  DateTime @default(now()) @map("created_at")

  @@unique([entityKind, fromSlug])
  @@map("slug_redirects")
}

// ---------------------------------------------------------------------------
// Growth — newsletter (Phase 1 KPI)
// ---------------------------------------------------------------------------

enum SubscriberStatus {
  PENDING
  CONFIRMED
  UNSUBSCRIBED
}

model NewsletterSubscriber {
  id        String           @id @default(uuid(7)) @db.Uuid
  email     String           @unique
  status    SubscriberStatus @default(PENDING)
  source    String?
  createdAt DateTime         @default(now()) @map("created_at")
  updatedAt DateTime         @updatedAt @map("updated_at")

  @@map("newsletter_subscribers")
}

// ---------------------------------------------------------------------------
// Semantic layer — pgvector embeddings (doc 06 §2).
// Queried via raw SQL behind the search repository (Prisma can't query
// Unsupported types directly).
// ---------------------------------------------------------------------------

model Embedding {
  id          String                       @id @default(uuid(7)) @db.Uuid
  subjectKind String                       @map("subject_kind") // entity | category | collection
  subjectId   String                       @map("subject_id") @db.Uuid
  contentHash String                       @map("content_hash")
  vector      Unsupported("vector(1024)")?
  createdAt   DateTime                     @default(now()) @map("created_at")

  @@unique([subjectKind, subjectId])
  @@map("embeddings")
}

// ---------------------------------------------------------------------------
// Eventing — transactional outbox (doc 02 §5)
// ---------------------------------------------------------------------------

model OutboxEvent {
  id          String    @id @default(uuid(7)) @db.Uuid
  topic       String
  payload     Json
  occurredAt  DateTime  @default(now()) @map("occurred_at")
  processedAt DateTime? @map("processed_at")
  attempts    Int       @default(0)

  @@index([processedAt, occurredAt])
  @@map("outbox_events")
}

// ---------------------------------------------------------------------------
// Payments & entitlements (doc 07 §8). Provider-agnostic internal model;
// provider adapters translate webhooks → these rows (webhooks are truth).
// Entitlements are separate from roles: premium access is derived from a paid
// subscription, never hand-set.
// ---------------------------------------------------------------------------

enum SubscriptionStatus {
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELED
  EXPIRED
}

model Subscription {
  id                 String             @id @default(uuid(7)) @db.Uuid
  userId             String             @map("user_id") @db.Uuid
  provider           String // "razorpay" | "paddle" | "mock"
  providerSubId      String             @unique @map("provider_sub_id")
  plan               String // "pro" | "team" | ...
  status             SubscriptionStatus @default(TRIALING)
  currentPeriodEnd   DateTime?          @map("current_period_end")
  cancelAtPeriodEnd  Boolean            @default(false) @map("cancel_at_period_end")
  createdAt          DateTime           @default(now()) @map("created_at")
  updatedAt          DateTime           @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("subscriptions")
}

model Entitlement {
  userId    String   @map("user_id") @db.Uuid
  feature   String // "advisor_unlimited" | "premium_content" | ...
  grantedAt DateTime @default(now()) @map("granted_at")
  expiresAt DateTime? @map("expires_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, feature])
  @@map("entitlements")
}

// ---------------------------------------------------------------------------
// DStarix Learn (doc 07 §3). Course → Lesson; content is MDX stored in DB.
// ---------------------------------------------------------------------------

enum ContentStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum CourseLevel {
  BEGINNER
  INTERMEDIATE
  ADVANCED
}

model Course {
  id          String        @id @default(uuid(7)) @db.Uuid
  slug        String        @unique
  title       String
  summary     String?
  level       CourseLevel   @default(BEGINNER)
  topic       String // e.g. "AI", "Python", "Cloud", "Data Science"
  status      ContentStatus @default(DRAFT)
  publishedAt DateTime?     @map("published_at")
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")

  lessons Lesson[]

  @@index([status, topic])
  @@map("courses")
}

model Lesson {
  id        String   @id @default(uuid(7)) @db.Uuid
  courseId  String   @map("course_id") @db.Uuid
  slug      String
  title     String
  bodyMdx   String   @map("body_mdx")
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([courseId, slug])
  @@index([courseId])
  @@map("lessons")
}

// ---------------------------------------------------------------------------
// DStarix Careers (doc 07 §5). Company is the SHARED entity with the catalog.
// ---------------------------------------------------------------------------

enum JobStatus {
  DRAFT
  PUBLISHED
  EXPIRED
  ARCHIVED
}

enum JobKind {
  FULL_TIME
  PART_TIME
  CONTRACT
  INTERNSHIP
}

model Job {
  id             String    @id @default(uuid(7)) @db.Uuid
  slug           String    @unique
  title          String
  companyId      String?   @map("company_id") @db.Uuid
  companyName    String    @map("company_name") // denormalized for aggregated postings
  location       String?
  remote         Boolean   @default(false)
  kind           JobKind   @default(FULL_TIME)
  description    String
  applyUrl       String    @map("apply_url")
  salaryMinMinor Int?      @map("salary_min_minor")
  salaryMaxMinor Int?      @map("salary_max_minor")
  salaryCurrency String    @default("USD") @map("salary_currency") @db.Char(3)
  status         JobStatus @default(DRAFT)
  source         String? // "aggregated" | "direct"
  publishedAt    DateTime? @map("published_at")
  expiresAt      DateTime? @map("expires_at")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  company Company? @relation(fields: [companyId], references: [id])

  @@index([status, publishedAt])
  @@index([companyId])
  @@map("jobs")
}

// ---------------------------------------------------------------------------
// Public API (doc 04 §3, Phase 4). Keys are stored hashed (never plaintext);
// the prefix is shown for identification. Usage is metered per key per day
// for billing and quota enforcement.
// ---------------------------------------------------------------------------

enum ApiPlan {
  FREE
  PRO
  ENTERPRISE
}

model ApiKey {
  id         String    @id @default(uuid(7)) @db.Uuid
  userId     String    @map("user_id") @db.Uuid
  name       String
  prefix     String    @unique // public identifier, e.g. "dsk_live_ab12"
  keyHash    String    @map("key_hash") // sha-256 of the full secret
  plan       ApiPlan   @default(FREE)
  lastUsedAt DateTime? @map("last_used_at")
  revokedAt  DateTime? @map("revoked_at")
  createdAt  DateTime  @default(now()) @map("created_at")

  user  User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  usage ApiUsageDay[]

  @@index([userId])
  @@map("api_keys")
}

model ApiUsageDay {
  apiKeyId String   @map("api_key_id") @db.Uuid
  day      DateTime @db.Date
  count    Int      @default(0)

  apiKey ApiKey @relation(fields: [apiKeyId], references: [id], onDelete: Cascade)

  @@id([apiKeyId, day])
  @@map("api_usage_days")
}

// ---------------------------------------------------------------------------
// Marketplace (doc 07 §2, Phase 4). Agents/prompts/templates commerce with a
// double-entry ledger as the money truth. Listings pass editorial review
// before publish (same trust bar as the catalog). Provider-agnostic like
// payments (ADR-011); mock provider drives the full order flow until real
// payout rails are configured.
// ---------------------------------------------------------------------------

enum MarketplaceListingType {
  AGENT
  PROMPT
  TEMPLATE
}

enum MarketplaceListingStatus {
  DRAFT
  IN_REVIEW
  PUBLISHED
  REJECTED
  ARCHIVED
}

enum OrderStatus {
  PENDING
  PAID
  REFUNDED
}

model MarketplaceListing {
  id            String                   @id @default(uuid(7)) @db.Uuid
  sellerId      String                   @map("seller_id") @db.Uuid
  slug          String                   @unique
  title         String
  summary       String
  type          MarketplaceListingType
  status        MarketplaceListingStatus @default(DRAFT)
  priceMinor    Int                      @map("price_minor") // 0 = free
  currency      String                   @default("USD") @db.Char(3)
  // Deliverable is released post-purchase; an R2 key for files, or inline text.
  deliverableText String?                @map("deliverable_text")
  deliverableKey  String?                @map("deliverable_key")
  publishedAt   DateTime?                @map("published_at")
  createdAt     DateTime                 @default(now()) @map("created_at")
  updatedAt     DateTime                 @updatedAt @map("updated_at")

  seller User               @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  orders MarketplaceOrder[]

  @@index([status, type])
  @@index([sellerId])
  @@map("marketplace_listings")
}

model MarketplaceOrder {
  id             String      @id @default(uuid(7)) @db.Uuid
  listingId      String      @map("listing_id") @db.Uuid
  buyerId        String      @map("buyer_id") @db.Uuid
  provider       String // "razorpay" | "paddle" | "mock"
  providerRef    String      @unique @map("provider_ref")
  amountMinor    Int         @map("amount_minor")
  platformFeeMinor Int       @map("platform_fee_minor")
  currency       String      @default("USD") @db.Char(3)
  status         OrderStatus @default(PENDING)
  createdAt      DateTime    @default(now()) @map("created_at")
  paidAt         DateTime?   @map("paid_at")

  listing MarketplaceListing @relation(fields: [listingId], references: [id])
  buyer   User               @relation(fields: [buyerId], references: [id])
  ledger  LedgerEntry[]

  @@index([buyerId])
  @@index([listingId])
  @@map("marketplace_orders")
}

// Double-entry ledger: entries for one order must sum to zero. Accounts are
// namespaced strings, e.g. "buyer:<id>", "seller:<id>", "platform:fees".
model LedgerEntry {
  id          String   @id @default(uuid(7)) @db.Uuid
  orderId     String   @map("order_id") @db.Uuid
  account     String
  amountMinor Int      @map("amount_minor") // signed: debit negative, credit positive
  currency    String   @default("USD") @db.Char(3)
  createdAt   DateTime @default(now()) @map("created_at")

  order MarketplaceOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([account])
  @@index([orderId])
  @@map("ledger_entries")
}

// ---------------------------------------------------------------------------
// Analytics — first-party event pipeline (doc 07 §6). Append-only; monthly
// partitioning + ClickHouse offload land when volume demands (>~5M/day).
// ---------------------------------------------------------------------------

model AnalyticsEvent {
  id        String   @id @default(uuid(7)) @db.Uuid
  name      String
  path      String?
  entityId  String?  @map("entity_id") @db.Uuid
  userId    String?  @map("user_id") @db.Uuid
  meta      Json     @default("{}")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([name, createdAt])
  @@index([entityId, name])
  @@map("analytics_events")
}

// ---------------------------------------------------------------------------
// Governance — audit log (doc 04 §5); append-only by convention
// ---------------------------------------------------------------------------

model AuditLog {
  id         String   @id @default(uuid(7)) @db.Uuid
  actorId    String?  @map("actor_id") @db.Uuid
  action     String
  resource   String
  resourceId String?  @map("resource_id")
  before     Json?
  after      Json?
  ip         String?
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([resource, resourceId])
  @@index([actorId, createdAt])
  @@map("audit_log")
}
